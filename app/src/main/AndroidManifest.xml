<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Internet permission for Retrofit API calls -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Lumora">

        <!-- Splash Screen - Launcher -->
        <activity
            android:name=".activities.SplashActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Main Activity -->
        <activity
            android:name=".activities.MainActivity"
            android:exported="false" />

        <!-- Login Activity -->
        <activity
            android:name=".activities.LoginActivity"
            android:exported="false" />

        <!-- Register Activity -->
        <activity
            android:name=".activities.RegisterActivity"
            android:exported="false" />

        <!-- Detail Activity -->
        <activity
            android:name=".activities.DetailActivity"
            android:exported="false"
            android:parentActivityName=".activities.MainActivity" />

        <!-- Learning Info Activity -->
        <activity
            android:name=".activities.LearningInfoActivity"
            android:exported="false"
            android:parentActivityName=".activities.DetailActivity" />

        <!-- Quiz Result Activity -->
        <activity
            android:name=".activities.QuizResultActivity"
            android:exported="false"
            android:parentActivityName=".activities.MainActivity" />

        <!-- Quiz Detail Activity -->
        <activity
            android:name=".activities.QuizDetailActivity"
            android:exported="false"
            android:parentActivityName=".activities.MainActivity" />

        <!-- Quiz Activity -->
        <activity
            android:name=".activities.QuizActivity"
            android:exported="false"
            android:parentActivityName=".activities.QuizDetailActivity" />

        <!-- Reader Activity -->
        <activity
            android:name=".activities.ReaderActivity"
            android:exported="false"
            android:parentActivityName=".activities.DetailActivity" />

        <!-- Learning Path Detail Activity -->
        <activity
            android:name=".activities.LearningPathDetailActivity"
            android:exported="false"
            android:parentActivityName=".activities.MainActivity" />

        <!-- Tutorial Detail Activity -->
        <activity
            android:name=".activities.TutorialDetailActivity"
            android:exported="false"
            android:parentActivityName=".activities.MainActivity" />

        <!-- Achievement Gallery Activity -->
        <activity
            android:name=".activities.AchievementGalleryActivity"
            android:exported="false"
            android:parentActivityName=".activities.MainActivity" />

        <!-- Offline Library Activity -->
        <activity
            android:name=".activities.OfflineLibraryActivity"
            android:exported="false"
            android:parentActivityName=".activities.MainActivity" />

        <!-- Onboarding Activity -->
        <activity
            android:name=".activities.OnboardingActivity"
            android:exported="false" />

        <!-- File Provider -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="com.lumora.app.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

            <activity android:name=".activities.CourseDetailActivity" android:exported="false" android:theme="@style/Theme.Lumora.Detail" />
        <activity android:name=".activities.ModuleDetailActivity" android:exported="false" android:theme="@style/Theme.Lumora.Detail" />
        <activity android:name=".activities.CertificateActivity" android:exported="false" android:theme="@style/Theme.Lumora.Detail" />
</application>

</manifest>