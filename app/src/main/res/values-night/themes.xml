<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Dark Theme -->
    <style name="Theme.Lumora" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Primary -->
        <item name="colorPrimary">@color/primary_light</item>
        <item name="colorPrimaryDark">#FF1E1B4B</item>
        <item name="colorPrimaryContainer">#FF312E81</item>
        <item name="colorOnPrimary">#FF1E1B4B</item>
        <item name="colorOnPrimaryContainer">@color/primary_light</item>

        <!-- Secondary -->
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSecondaryContainer">#FF312E81</item>
        <item name="colorOnSecondary">#FF1E1B4B</item>
        <item name="colorOnSecondaryContainer">@color/secondary</item>

        <!-- Tertiary -->
        <item name="colorTertiary">@color/tertiary</item>
        <item name="colorTertiaryContainer">#FF164E63</item>
        <item name="colorOnTertiary">#FF083344</item>

        <!-- Background & Surface -->
        <item name="android:colorBackground">#FF121212</item>
        <item name="colorSurface">#FF1E1E1E</item>
        <item name="colorSurfaceVariant">#FF2D2D2D</item>
        <item name="colorOnBackground">#FFE2E8F0</item>
        <item name="colorOnSurface">#FFE2E8F0</item>
        <item name="colorOnSurfaceVariant">#FF94A3B8</item>

        <!-- Error -->
        <item name="colorError">#FFFCA5A5</item>
        <item name="colorErrorContainer">#FF7F1D1D</item>
        <item name="colorOnError">#FF450A0A</item>
        <item name="colorOnErrorContainer">#FFFCA5A5</item>

        <!-- Outline -->
        <item name="colorOutline">#FF475569</item>
        <item name="colorOutlineVariant">#FF334155</item>

        <!-- Status Bar -->
        <item name="android:statusBarColor">#FF121212</item>
        <item name="android:navigationBarColor">#FF1E1E1E</item>
    </style>

    <!-- Detail Activity Dark Theme -->
    <style name="Theme.Lumora.Detail" parent="Theme.Lumora">
        <item name="android:statusBarColor">#FF121212</item>
    </style>

</resources>