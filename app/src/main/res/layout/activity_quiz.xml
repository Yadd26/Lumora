<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground">

    <!-- AppBar & Toolbar -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_gradient_primary"
        app:elevation="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@drawable/ic_back"
            app:navigationIconTint="@android:color/white"
            app:title="Pengerjaan Kuis"
            app:titleTextColor="@android:color/white" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Scrollable Question Form -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/layout_navigation_buttons"
        app:layout_constraintTop_toBottomOf="@id/app_bar_layout">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Question Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="?attr/colorSurface"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Progress Bar & Count Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <com.google.android.material.progressindicator.LinearProgressIndicator
                            android:id="@+id/progress_quiz"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:max="10"
                            android:progress="1"
                            app:trackCornerRadius="4dp" />

                        <TextView
                            android:id="@+id/text_question_number"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:text="Soal 1 dari 10"
                            android:textAppearance="?attr/textAppearanceLabelLarge"
                            android:textColor="@color/primary"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <!-- Question Text -->
                    <TextView
                        android:id="@+id/text_question"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Teks pertanyaan akan dimuat di sini?"
                        android:textAppearance="?attr/textAppearanceTitleLarge"
                        android:textColor="?attr/colorOnSurface"
                        android:textStyle="bold"
                        android:lineSpacingMultiplier="1.1" />

                    <com.google.android.material.divider.MaterialDivider
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="16dp" />

                    <!-- Answer choices RadioGroup -->
                    <RadioGroup
                        android:id="@+id/radio_group_answers"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/radio_option_1"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginVertical="6dp"
                            android:background="@drawable/bg_search_bar"
                            android:padding="16dp"
                            android:text="Opsi A"
                            android:textAppearance="?attr/textAppearanceBodyMedium"
                            android:button="@null"
                            android:drawableEnd="?android:attr/listChoiceIndicatorSingle" />

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/radio_option_2"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginVertical="6dp"
                            android:background="@drawable/bg_search_bar"
                            android:padding="16dp"
                            android:text="Opsi B"
                            android:textAppearance="?attr/textAppearanceBodyMedium"
                            android:button="@null"
                            android:drawableEnd="?android:attr/listChoiceIndicatorSingle" />

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/radio_option_3"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginVertical="6dp"
                            android:background="@drawable/bg_search_bar"
                            android:padding="16dp"
                            android:text="Opsi C"
                            android:textAppearance="?attr/textAppearanceBodyMedium"
                            android:button="@null"
                            android:drawableEnd="?android:attr/listChoiceIndicatorSingle" />

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/radio_option_4"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginVertical="6dp"
                            android:background="@drawable/bg_search_bar"
                            android:padding="16dp"
                            android:text="Opsi D"
                            android:textAppearance="?attr/textAppearanceBodyMedium"
                            android:button="@null"
                            android:drawableEnd="?android:attr/listChoiceIndicatorSingle" />

                    </RadioGroup>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </ScrollView>

    <!-- Bottom Navigation Buttons Bar (Sebelumnya & Selanjutnya) -->
    <LinearLayout
        android:id="@+id/layout_navigation_buttons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface"
        android:elevation="8dp"
        android:orientation="horizontal"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_prev_question"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="Sebelumnya"
            android:textStyle="bold"
            app:cornerRadius="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_next_question"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_weight="1.2"
            android:layout_marginStart="8dp"
            android:text="Selanjutnya"
            android:textStyle="bold"
            app:cornerRadius="12dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
