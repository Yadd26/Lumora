<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_parchment_card"
    android:orientation="horizontal"
    android:padding="12dp"
    android:layout_marginBottom="10dp"
    android:gravity="center_vertical">

    <!-- Cover placeholder/image -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="60dp"
        android:layout_height="80dp"
        app:cardCornerRadius="4dp"
        app:strokeWidth="1dp"
        app:strokeColor="#C8A165"
        android:layout_marginEnd="12dp">

        <ImageView
            android:id="@+id/img_book_cover"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/ic_open_book"
            android:scaleType="centerCrop"
            android:importantForAccessibility="no" />

    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/text_book_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Judul Buku Klasik"
            android:textColor="#3E2723"
            android:textStyle="bold"
            android:textSize="14sp"
            android:maxLines="2"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/text_book_author"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Penulis Klasik"
            android:textColor="#5C3D2E"
            android:textSize="12sp"
            android:layout_marginTop="2dp" />

        <!-- Progress bar and text -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">

            <ProgressBar
                android:id="@+id/progress_reading"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_height="6dp"
                android:layout_weight="1"
                android:max="100"
                android:progress="40"
                android:progressTint="#C8A165"
                android:progressBackgroundTint="#EFE5D3" />

            <TextView
                android:id="@+id/text_progress_percent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="40%"
                android:textColor="#C8A165"
                android:textSize="11sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_open_book"
        style="@style/Widget.Material3.Button.TonalButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:text="BACA"
        android:textColor="#FAF4E8"
        app:backgroundTint="#5C3D2E"
        android:textSize="11sp"
        android:insetTop="0dp"
        android:insetBottom="0dp" />

</LinearLayout>
