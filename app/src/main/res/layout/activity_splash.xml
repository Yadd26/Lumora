<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Center Logo and Title Container -->
    <LinearLayout
        android:id="@+id/layout_logo_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Logo Frame with Glow Effect -->
        <FrameLayout
            android:layout_width="140dp"
            android:layout_height="140dp">

            <!-- Glowing background aura behind the card -->
            <View
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_logo_gold_glow" />

            <!-- Logo Card (Parchment Background, Gold Border) -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:layout_gravity="center"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="24dp"
                app:cardElevation="4dp"
                app:strokeColor="@color/tertiary"
                app:strokeWidth="1.5dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <!-- Inner circular highlight -->
                    <View
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_avatar_circle"
                        android:backgroundTint="#15C8A165" />

                    <!-- Official Logo Image -->
                    <ImageView
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_logo_lumora"
                        android:contentDescription="Lumora Logo" />

                </FrameLayout>

            </com.google.android.material.card.MaterialCardView>

        </FrameLayout>

        <!-- App Name -->
        <TextView
            android:id="@+id/text_app_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/app_name"
            android:fontFamily="@font/cinzel"
            android:textAppearance="?attr/textAppearanceHeadlineMedium"
            android:textColor="@color/primary"
            android:textStyle="bold"
            android:letterSpacing="0.1" />

        <!-- Tagline -->
        <TextView
            android:id="@+id/text_tagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/app_tagline"
            android:fontFamily="@font/cormorant_garamond"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="@color/text_secondary"
            android:textStyle="italic" />

        <!-- Pulse Loading text -->
        <TextView
            android:id="@+id/text_loading_progress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="Memuat Arsip Pengetahuan..."
            android:fontFamily="@font/cormorant_garamond"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="@color/tertiary"
            android:letterSpacing="0.1" />

        <!-- Circular Progress Indicator -->
        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/progress_indicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:indeterminate="true"
            app:indicatorColor="@color/tertiary"
            app:trackColor="@color/surface_variant" />

    </LinearLayout>

    <!-- Version Code at Bottom -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:text="@string/version"
        android:fontFamily="@font/cormorant_garamond"
        android:textAppearance="?attr/textAppearanceLabelSmall"
        android:textColor="@color/text_secondary"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
