<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground">

    <!-- Header Section -->
    <LinearLayout
        android:id="@+id/header_section"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_gradient_primary"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="24dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/text_home_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/home_title"
            android:textAppearance="?attr/textAppearanceHeadlineMedium"
            android:textColor="@android:color/white"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/text_home_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:alpha="0.85"
            android:text="Pusat Pembelajaran &amp; Referensi Digital"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="@android:color/white" />

        <!-- Search Bar -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="#33FFFFFF"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <androidx.appcompat.widget.SearchView
                android:id="@+id/search_view"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:iconifiedByDefault="false"
                app:iconifiedByDefault="false"
                app:queryHint="Cari judul, penulis, kategori…"
                app:searchHintIcon="@null" />

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

    <!-- SwipeRefreshLayout wrapping all content views -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipe_refresh"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/header_section">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- Default Main Dashboard (Scrollable Hub) -->
            <androidx.core.widget.NestedScrollView
                android:id="@+id/layout_dashboard"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="visible">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingVertical="16dp">

                    <!-- Section: Rekomendasi Hari Ini -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="16dp"
                        android:text="Rekomendasi Hari Ini"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:textColor="?attr/colorOnSurface"
                        android:textStyle="bold" />

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_recommendation"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="16dp"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="20dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardBackgroundColor="?attr/colorSurfaceVariant"
                        app:cardCornerRadius="16dp"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:padding="16dp">

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="80dp"
                                android:layout_height="112dp"
                                app:cardCornerRadius="8dp"
                                app:strokeWidth="0dp"
                                app:cardElevation="0dp">

                                <ImageView
                                    android:id="@+id/image_recommend_cover"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:scaleType="centerCrop"
                                    android:src="@drawable/ic_bookmark_outline" />

                            </com.google.android.material.card.MaterialCardView>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:layout_marginStart="16dp"
                                android:gravity="center_vertical"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:background="@drawable/bg_search_bar"
                                    android:paddingHorizontal="8dp"
                                    android:paddingVertical="2dp"
                                    android:text="PILIHAN TERBAIK"
                                    android:textAppearance="?attr/textAppearanceLabelSmall"
                                    android:textColor="@color/primary"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/text_recommend_title"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="6dp"
                                    android:ellipsize="end"
                                    android:maxLines="2"
                                    android:text="Memuat buku pilihan..."
                                    android:textAppearance="?attr/textAppearanceTitleMedium"
                                    android:textColor="?attr/colorOnSurface"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/text_recommend_author"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:ellipsize="end"
                                    android:maxLines="1"
                                    android:text="-"
                                    android:textAppearance="?attr/textAppearanceBodyMedium"
                                    android:textColor="?attr/colorOnSurfaceVariant" />

                            </LinearLayout>

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <!-- Section: Kategori Pembelajaran -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="16dp"
                        android:text="Kategori Pembelajaran"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:textColor="?attr/colorOnSurface"
                        android:textStyle="bold" />

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="24dp"
                        android:scrollbars="none"
                        android:paddingHorizontal="12dp"
                        android:clipToPadding="false">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <!-- Kategori Pemrograman -->
                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/cat_pemrograman"
                                android:layout_width="140dp"
                                android:layout_height="80dp"
                                android:layout_margin="4dp"
                                android:clickable="true"
                                android:focusable="true"
                                app:cardCornerRadius="12dp"
                                app:cardBackgroundColor="?attr/colorSurfaceVariant">

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:gravity="center"
                                    android:padding="8dp"
                                    android:text="Pemrograman"
                                    android:textStyle="bold"
                                    android:textColor="?attr/colorOnSurfaceVariant" />
                            </com.google.android.material.card.MaterialCardView>

                            <!-- Kategori Basis Data -->
                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/cat_basis_data"
                                android:layout_width="140dp"
                                android:layout_height="80dp"
                                android:layout_margin="4dp"
                                android:clickable="true"
                                android:focusable="true"
                                app:cardCornerRadius="12dp"
                                app:cardBackgroundColor="?attr/colorSurfaceVariant">
                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:gravity="center"
                                    android:padding="8dp"
                                    android:text="Basis Data"
                                    android:textStyle="bold"
                                    android:textColor="?attr/colorOnSurfaceVariant" />
                            </com.google.android.material.card.MaterialCardView>

                            <!-- Kategori Jaringan Komputer -->
                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/cat_jaringan"
                                android:layout_width="140dp"
                                android:layout_height="80dp"
                                android:layout_margin="4dp"
                                android:clickable="true"
                                android:focusable="true"
                                app:cardCornerRadius="12dp"
                                app:cardBackgroundColor="?attr/colorSurfaceVariant">
                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:gravity="center"
                                    android:padding="8dp"
                                    android:text="Jaringan Komputer"
                                    android:textStyle="bold"
                                    android:textColor="?attr/colorOnSurfaceVariant" />
                            </com.google.android.material.card.MaterialCardView>

                            <!-- Kategori Sistem Informasi -->
                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/cat_sistem_informasi"
                                android:layout_width="140dp"
                                android:layout_height="80dp"
                                android:layout_margin="4dp"
                                android:clickable="true"
                                android:focusable="true"
                                app:cardCornerRadius="12dp"
                                app:cardBackgroundColor="?attr/colorSurfaceVariant">
                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:gravity="center"
                                    android:padding="8dp"
                                    android:text="Sistem Informasi"
                                    android:textStyle="bold"
                                    android:textColor="?attr/colorOnSurfaceVariant" />
                            </com.google.android.material.card.MaterialCardView>

                            <!-- Kategori AI -->
                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/cat_ai"
                                android:layout_width="140dp"
                                android:layout_height="80dp"
                                android:layout_margin="4dp"
                                android:clickable="true"
                                android:focusable="true"
                                app:cardCornerRadius="12dp"
                                app:cardBackgroundColor="?attr/colorSurfaceVariant">
                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:gravity="center"
                                    android:padding="8dp"
                                    android:text="Artificial Intelligence"
                                    android:textStyle="bold"
                                    android:textColor="?attr/colorOnSurfaceVariant" />
                            </com.google.android.material.card.MaterialCardView>

                            <!-- Kategori Data Science -->
                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/cat_data_science"
                                android:layout_width="140dp"
                                android:layout_height="80dp"
                                android:layout_margin="4dp"
                                android:clickable="true"
                                android:focusable="true"
                                app:cardCornerRadius="12dp"
                                app:cardBackgroundColor="?attr/colorSurfaceVariant">
                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:gravity="center"
                                    android:padding="8dp"
                                    android:text="Data Science"
                                    android:textStyle="bold"
                                    android:textColor="?attr/colorOnSurfaceVariant" />
                            </com.google.android.material.card.MaterialCardView>

                            <!-- Kategori Cyber Security -->
                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/cat_security"
                                android:layout_width="140dp"
                                android:layout_height="80dp"
                                android:layout_margin="4dp"
                                android:clickable="true"
                                android:focusable="true"
                                app:cardCornerRadius="12dp"
                                app:cardBackgroundColor="?attr/colorSurfaceVariant">
                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:gravity="center"
                                    android:padding="8dp"
                                    android:text="Cyber Security"
                                    android:textStyle="bold"
                                    android:textColor="?attr/colorOnSurfaceVariant" />
                            </com.google.android.material.card.MaterialCardView>

                            <!-- Kategori Mobile Development -->
                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/cat_mobile"
                                android:layout_width="140dp"
                                android:layout_height="80dp"
                                android:layout_margin="4dp"
                                android:clickable="true"
                                android:focusable="true"
                                app:cardCornerRadius="12dp"
                                app:cardBackgroundColor="?attr/colorSurfaceVariant">
                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:gravity="center"
                                    android:padding="8dp"
                                    android:text="Mobile Dev"
                                    android:textStyle="bold"
                                    android:textColor="?attr/colorOnSurfaceVariant" />
                            </com.google.android.material.card.MaterialCardView>

                        </LinearLayout>

                    </HorizontalScrollView>

                    <!-- Horizontal Book Section: Buku Populer -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="16dp"
                        android:text="Buku Populer"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:textColor="?attr/colorOnSurface"
                        android:textStyle="bold" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recycler_popular"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="20dp"
                        android:orientation="horizontal"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                        tools:listitem="@layout/item_material" />

                    <!-- Horizontal Book Section: Pemrograman -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="16dp"
                        android:text="Buku Pemrograman"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:textColor="?attr/colorOnSurface"
                        android:textStyle="bold" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recycler_programming"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="20dp"
                        android:orientation="horizontal"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                        tools:listitem="@layout/item_material" />

                    <!-- Horizontal Book Section: Basis Data -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="16dp"
                        android:text="Buku Basis Data"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:textColor="?attr/colorOnSurface"
                        android:textStyle="bold" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recycler_database"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="20dp"
                        android:orientation="horizontal"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                        tools:listitem="@layout/item_material" />

                    <!-- Horizontal Book Section: Jaringan Komputer -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="16dp"
                        android:text="Buku Jaringan Komputer"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:textColor="?attr/colorOnSurface"
                        android:textStyle="bold" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recycler_networking"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="20dp"
                        android:orientation="horizontal"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                        tools:listitem="@layout/item_material" />

                    <!-- Horizontal Book Section: Kecerdasan Buatan -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="16dp"
                        android:text="Buku Kecerdasan Buatan"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:textColor="?attr/colorOnSurface"
                        android:textStyle="bold" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recycler_ai"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="20dp"
                        android:orientation="horizontal"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                        tools:listitem="@layout/item_material" />

                </LinearLayout>

            </androidx.core.widget.NestedScrollView>

            <!-- Search Results State (Vertical RecyclerView) -->
            <LinearLayout
                android:id="@+id/layout_search_results"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="12dp">

                    <TextView
                        android:id="@+id/text_search_header"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Hasil Pencarian"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:textColor="?attr/colorOnSurface"
                        android:textStyle="bold" />

                    <!-- Close Search button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_close_search"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tutup" />

                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recycler_search_list"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clipToPadding="false"
                    android:padding="8dp"
                    tools:listitem="@layout/item_material" />

            </LinearLayout>

            <!-- Loading State -->
            <LinearLayout
                android:id="@+id/layout_loading"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="gone">

                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:indeterminate="true"
                    app:indicatorColor="@color/primary"
                    app:trackThickness="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Mengambil materi belajar..."
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="?attr/colorOnSurfaceVariant" />

            </LinearLayout>

            <!-- Empty State -->
            <LinearLayout
                android:id="@+id/layout_empty"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="32dp"
                android:visibility="gone">

                <ImageView
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:alpha="0.5"
                    android:src="@drawable/ic_empty_state"
                    android:contentDescription="Tidak ditemukan" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Buku Tidak Ditemukan"
                    android:textAppearance="?attr/textAppearanceTitleMedium"
                    android:textColor="?attr/colorOnSurface" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:text="Silakan gunakan kata kunci pencarian yang lain."
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="?attr/colorOnSurfaceVariant" />

            </LinearLayout>

            <!-- Error State -->
            <LinearLayout
                android:id="@+id/layout_error"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="32dp"
                android:visibility="gone">

                <ImageView
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:alpha="0.5"
                    android:src="@drawable/ic_error_state"
                    android:contentDescription="@string/error_loading" />

                <TextView
                    android:id="@+id/text_error_message"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/error_loading"
                    android:textAppearance="?attr/textAppearanceTitleMedium"
                    android:textColor="?attr/colorOnSurface" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_retry"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/retry"
                    app:cornerRadius="8dp" />

            </LinearLayout>

        </FrameLayout>

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
