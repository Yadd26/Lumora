<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Header Section (Wooden Style Dark Brown Gradient) -->
    <LinearLayout
        android:id="@+id/header_section"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_gradient_primary"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="24dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/text_home_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/home_title"
            android:fontFamily="@font/cinzel"
            android:textAppearance="?attr/textAppearanceHeadlineMedium"
            android:textColor="@color/on_primary"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/text_home_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:alpha="0.9"
            android:text="@string/home_subtitle"
            android:fontFamily="@font/cormorant_garamond"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="@color/on_primary" />

        <!-- Search Bar (Parchment background with gold border overlay) -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="#20FFFFFF"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/tertiary"
            app:strokeWidth="1dp">

            <androidx.appcompat.widget.SearchView
                android:id="@+id/search_view"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:iconifiedByDefault="false"
                app:iconifiedByDefault="false"
                app:queryHint="@string/search_hint"
                app:searchHintIcon="@null" />

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

    <!-- SwipeRefreshLayout wrapping all content views -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipe_refresh"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/header_section">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- Default Main Dashboard (Scrollable Hub) -->
            <androidx.core.widget.NestedScrollView
                android:id="@+id/layout_dashboard"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="visible">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingVertical="16dp">

                    <!-- Section: Menu Akademik (Quick Access to Quiz & Resources) -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="16dp"
                        android:text="Lembaga Akademik"
                        android:fontFamily="@font/cinzel"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="12dp"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="16dp"
                        android:orientation="vertical">

                        <!-- Row 1 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <!-- Quick Access: Kuis Kategori -->
                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/btn_quick_quiz"
                                android:layout_width="0dp"
                                android:layout_height="88dp"
                                android:layout_margin="4dp"
                                android:layout_weight="1"
                                android:clickable="true"
                                android:focusable="true"
                                app:cardBackgroundColor="@color/surface"
                                app:cardCornerRadius="16dp"
                                app:strokeColor="@color/tertiary"
                                app:strokeWidth="1.2dp">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:gravity="center"
                                    android:orientation="vertical"
                                    android:padding="8dp">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="📜"
                                        android:textSize="24sp" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="4dp"
                                        android:text="Ujian Kuis"
                                        android:fontFamily="@font/cinzel"
                                        android:textColor="@color/primary"
                                        android:textSize="13sp"
                                        android:textStyle="bold" />
                                </LinearLayout>
                            </com.google.android.material.card.MaterialCardView>

                            <!-- Quick Access: Jalur Pembelajaran -->
                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/btn_quick_learning_path"
                                android:layout_width="0dp"
                                android:layout_height="88dp"
                                android:layout_margin="4dp"
                                android:layout_weight="1"
                                android:clickable="true"
                                android:focusable="true"
                                app:cardBackgroundColor="@color/surface"
                                app:cardCornerRadius="16dp"
                                app:strokeColor="@color/tertiary"
                                app:strokeWidth="1.2dp">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:gravity="center"
                                    android:orientation="vertical"
                                    android:padding="8dp">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="🗺️"
                                        android:textSize="24sp" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="4dp"
                                        android:text="Jalur Belajar"
                                        android:fontFamily="@font/cinzel"
                                        android:textColor="@color/primary"
                                        android:textSize="13sp"
                                        android:textStyle="bold" />
                                </LinearLayout>
                            </com.google.android.material.card.MaterialCardView>

                        </LinearLayout>

                        <!-- Row 2 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <!-- Quick Access: Panduan Akademik / Tutorial -->
                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/btn_quick_tutorials"
                                android:layout_width="0dp"
                                android:layout_height="88dp"
                                android:layout_margin="4dp"
                                android:layout_weight="1"
                                android:clickable="true"
                                android:focusable="true"
                                app:cardBackgroundColor="@color/surface"
                                app:cardCornerRadius="16dp"
                                app:strokeColor="@color/tertiary"
                                app:strokeWidth="1.2dp">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:gravity="center"
                                    android:orientation="vertical"
                                    android:padding="8dp">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="💻"
                                        android:textSize="24sp" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="4dp"
                                        android:text="Panduan Kode"
                                        android:fontFamily="@font/cinzel"
                                        android:textColor="@color/primary"
                                        android:textSize="13sp"
                                        android:textStyle="bold" />
                                </LinearLayout>
                            </com.google.android.material.card.MaterialCardView>

                            <!-- Quick Access: Rencana Belajar -->
                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/btn_quick_resources"
                                android:layout_width="0dp"
                                android:layout_height="88dp"
                                android:layout_margin="4dp"
                                android:layout_weight="1"
                                android:clickable="true"
                                android:focusable="true"
                                app:cardBackgroundColor="@color/surface"
                                app:cardCornerRadius="16dp"
                                app:strokeColor="@color/tertiary"
                                app:strokeWidth="1.2dp">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:gravity="center"
                                    android:orientation="vertical"
                                    android:padding="8dp">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="📚"
                                        android:textSize="24sp" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="4dp"
                                        android:text="Arsip Rencana"
                                        android:fontFamily="@font/cinzel"
                                        android:textColor="@color/primary"
                                        android:textSize="13sp"
                                        android:textStyle="bold" />
                                </LinearLayout>
                            </com.google.android.material.card.MaterialCardView>

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Section: Lanjutkan Membaca -->
                    <LinearLayout
                        android:id="@+id/layout_continue_reading"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="20dp"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginHorizontal="16dp"
                            android:text="Lanjutkan Membaca"
                            android:fontFamily="@font/cinzel"
                            android:textAppearance="?attr/textAppearanceTitleMedium"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold" />

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rv_continue_reading"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="8dp"
                            android:paddingHorizontal="12dp"
                            android:clipToPadding="false"
                            tools:listitem="@layout/item_continue_reading" />

                    </LinearLayout>

                    <!-- Section: Riwayat Pembelajaran -->
                    <LinearLayout
                        android:id="@+id/layout_learning_history_section"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginHorizontal="16dp"
                            android:text="Riwayat Pembelajaran"
                            android:fontFamily="@font/cinzel"
                            android:textAppearance="?attr/textAppearanceTitleMedium"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold" />

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rv_learning_history"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:nestedScrollingEnabled="false"
                            tools:listitem="@layout/item_learning_history" />

                    </LinearLayout>

                    <!-- Section: Rekomendasi Akademik -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="16dp"
                        android:text="Rekomendasi Akademik"
                        android:fontFamily="@font/cinzel"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold" />

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_recommendation"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="16dp"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="20dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardBackgroundColor="@color/surface"
                        app:cardCornerRadius="16dp"
                        app:strokeColor="@color/tertiary"
                        app:strokeWidth="1.2dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:padding="16dp">

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="80dp"
                                android:layout_height="112dp"
                                app:cardCornerRadius="8dp"
                                app:strokeColor="@color/tertiary"
                                app:strokeWidth="1dp"
                                app:cardElevation="0dp">

                                <ImageView
                                    android:id="@+id/image_recommend_cover"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:scaleType="centerCrop"
                                    android:src="@drawable/ic_bookmark_outline" />

                            </com.google.android.material.card.MaterialCardView>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:layout_marginStart="16dp"
                                android:gravity="center_vertical"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:background="@drawable/bg_search_bar"
                                    android:backgroundTint="@color/primary"
                                    android:paddingHorizontal="8dp"
                                    android:paddingVertical="2dp"
                                    android:text="PILIHAN TERBAIK"
                                    android:fontFamily="@font/cinzel"
                                    android:textAppearance="?attr/textAppearanceLabelSmall"
                                    android:textColor="@color/on_primary"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/text_recommend_title"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="8dp"
                                    android:ellipsize="end"
                                    android:maxLines="2"
                                    android:text="Memuat buku pilihan..."
                                    android:fontFamily="@font/cinzel"
                                    android:textAppearance="?attr/textAppearanceTitleMedium"
                                    android:textColor="@color/text_primary"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/text_recommend_author"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:ellipsize="end"
                                    android:maxLines="1"
                                    android:text="-"
                                    android:fontFamily="@font/cormorant_garamond"
                                    android:textAppearance="?attr/textAppearanceBodyMedium"
                                    android:textColor="@color/text_secondary" />

                            </LinearLayout>

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <!-- Section: Kategori Pembelajaran -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="16dp"
                        android:text="Arsip Departemen"
                        android:fontFamily="@font/cinzel"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold" />

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="24dp"
                        android:scrollbars="none"
                        android:paddingHorizontal="12dp"
                        android:clipToPadding="false">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <!-- Kategori Pemrograman -->
                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/cat_pemrograman"
                                android:layout_width="140dp"
                                android:layout_height="64dp"
                                android:layout_margin="4dp"
                                android:clickable="true"
                                android:focusable="true"
                                app:cardCornerRadius="12dp"
                                app:cardBackgroundColor="@color/surface"
                                app:strokeColor="@color/tertiary"
                                app:strokeWidth="1.2dp">
                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:gravity="center"
                                    android:padding="8dp"
                                    android:text="Pemrograman"
                                    android:fontFamily="@font/cormorant_garamond"
                                    android:textStyle="bold"
                                    android:textColor="@color/text_primary" />
                            </com.google.android.material.card.MaterialCardView>

                            <!-- Kategori Basis Data -->
                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/cat_basis_data"
                                android:layout_width="140dp"
                                android:layout_height="64dp"
                                android:layout_margin="4dp"
                                android:clickable="true"
                                android:focusable="true"
                                app:cardCornerRadius="12dp"
                                app:cardBackgroundColor="@color/surface"
                                app:strokeColor="@color/tertiary"
                                app:strokeWidth="1.2dp">
                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:gravity="center"
                                    android:padding="8dp"
                                    android:text="Basis Data"
                                    android:fontFamily="@font/cormorant_garamond"
                                    android:textStyle="bold"
                                    android:textColor="@color/text_primary" />
                            </com.google.android.material.card.MaterialCardView>

                            <!-- Kategori Jaringan Komputer -->
                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/cat_jaringan"
                                android:layout_width="140dp"
                                android:layout_height="64dp"
                                android:layout_margin="4dp"
                                android:clickable="true"
                                android:focusable="true"
                                app:cardCornerRadius="12dp"
                                app:cardBackgroundColor="@color/surface"
                                app:strokeColor="@color/tertiary"
                                app:strokeWidth="1.2dp">
                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:gravity="center"
                                    android:padding="8dp"
                                    android:text="Jaringan Komputer"
                                    android:fontFamily="@font/cormorant_garamond"
                                    android:textStyle="bold"
                                    android:textColor="@color/text_primary" />
                            </com.google.android.material.card.MaterialCardView>

                            <!-- Kategori Sistem Informasi -->
                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/cat_sistem_informasi"
                                android:layout_width="140dp"
                                android:layout_height="64dp"
                                android:layout_margin="4dp"
                                android:clickable="true"
                                android:focusable="true"
                                app:cardCornerRadius="12dp"
                                app:cardBackgroundColor="@color/surface"
                                app:strokeColor="@color/tertiary"
                                app:strokeWidth="1.2dp">
                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:gravity="center"
                                    android:padding="8dp"
                                    android:text="Sistem Informasi"
                                    android:fontFamily="@font/cormorant_garamond"
                                    android:textStyle="bold"
                                    android:textColor="@color/text_primary" />
                            </com.google.android.material.card.MaterialCardView>

                            <!-- Kategori AI -->
                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/cat_ai"
                                android:layout_width="140dp"
                                android:layout_height="64dp"
                                android:layout_margin="4dp"
                                android:clickable="true"
                                android:focusable="true"
                                app:cardCornerRadius="12dp"
                                app:cardBackgroundColor="@color/surface"
                                app:strokeColor="@color/tertiary"
                                app:strokeWidth="1.2dp">
                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:gravity="center"
                                    android:padding="8dp"
                                    android:text="Artificial Intelligence"
                                    android:fontFamily="@font/cormorant_garamond"
                                    android:textStyle="bold"
                                    android:textColor="@color/text_primary" />
                            </com.google.android.material.card.MaterialCardView>

                            <!-- Kategori Data Science -->
                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/cat_data_science"
                                android:layout_width="140dp"
                                android:layout_height="64dp"
                                android:layout_margin="4dp"
                                android:clickable="true"
                                android:focusable="true"
                                app:cardCornerRadius="12dp"
                                app:cardBackgroundColor="@color/surface"
                                app:strokeColor="@color/tertiary"
                                app:strokeWidth="1.2dp">
                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:gravity="center"
                                    android:padding="8dp"
                                    android:text="Data Science"
                                    android:fontFamily="@font/cormorant_garamond"
                                    android:textStyle="bold"
                                    android:textColor="@color/text_primary" />
                            </com.google.android.material.card.MaterialCardView>

                            <!-- Kategori Cyber Security -->
                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/cat_security"
                                android:layout_width="140dp"
                                android:layout_height="64dp"
                                android:layout_margin="4dp"
                                android:clickable="true"
                                android:focusable="true"
                                app:cardCornerRadius="12dp"
                                app:cardBackgroundColor="@color/surface"
                                app:strokeColor="@color/tertiary"
                                app:strokeWidth="1.2dp">
                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:gravity="center"
                                    android:padding="8dp"
                                    android:text="Cyber Security"
                                    android:fontFamily="@font/cormorant_garamond"
                                    android:textStyle="bold"
                                    android:textColor="@color/text_primary" />
                            </com.google.android.material.card.MaterialCardView>

                            <!-- Kategori Mobile Development -->
                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/cat_mobile"
                                android:layout_width="140dp"
                                android:layout_height="64dp"
                                android:layout_margin="4dp"
                                android:clickable="true"
                                android:focusable="true"
                                app:cardCornerRadius="12dp"
                                app:cardBackgroundColor="@color/surface"
                                app:strokeColor="@color/tertiary"
                                app:strokeWidth="1.2dp">
                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:gravity="center"
                                    android:padding="8dp"
                                    android:text="Mobile Dev"
                                    android:fontFamily="@font/cormorant_garamond"
                                    android:textStyle="bold"
                                    android:textColor="@color/text_primary" />
                            </com.google.android.material.card.MaterialCardView>

                        </LinearLayout>

                    </HorizontalScrollView>

                    <!-- Horizontal Book Section: Buku Populer -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="16dp"
                        android:text="Buku Populer"
                        android:fontFamily="@font/cinzel"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recycler_popular"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="20dp"
                        android:orientation="horizontal"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                        tools:listitem="@layout/item_material" />

                    <!-- Horizontal Book Section: Referensi Terbaru -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="16dp"
                        android:text="Referensi Terbaru"
                        android:fontFamily="@font/cinzel"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recycler_programming"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="20dp"
                        android:orientation="horizontal"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                        tools:listitem="@layout/item_material" />

                    <!-- Horizontal Book Section: Koleksi Favorit -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="16dp"
                        android:text="Koleksi Favorit"
                        android:fontFamily="@font/cinzel"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recycler_database"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="20dp"
                        android:orientation="horizontal"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                        tools:listitem="@layout/item_material" />

                    <!-- Horizontal Book Section: Jaringan Komputer (Hidden/styled compatibility) -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recycler_networking"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="0dp"
                        android:layout_marginBottom="0dp"
                        android:visibility="gone" />

                    <!-- Horizontal Book Section: Kecerdasan Buatan (Hidden/styled compatibility) -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recycler_ai"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="0dp"
                        android:layout_marginBottom="0dp"
                        android:visibility="gone" />

                </LinearLayout>

            </androidx.core.widget.NestedScrollView>

            <!-- Search Results State (Vertical RecyclerView) -->
            <LinearLayout
                android:id="@+id/layout_search_results"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="12dp">

                    <TextView
                        android:id="@+id/text_search_header"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Hasil Pencarian"
                        android:fontFamily="@font/cinzel"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold" />

                    <!-- Close Search button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_close_search"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tutup"
                        android:fontFamily="@font/cinzel"
                        android:textColor="@color/primary" />

                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recycler_search_list"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clipToPadding="false"
                    android:padding="8dp"
                    tools:listitem="@layout/item_material" />

            </LinearLayout>

            <!-- Loading State -->
            <LinearLayout
                android:id="@+id/layout_loading"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="gone">

                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:indeterminate="true"
                    app:indicatorColor="@color/primary"
                    app:trackThickness="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Mengambil arsip perpustakaan..."
                    android:fontFamily="@font/cormorant_garamond"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="@color/text_secondary" />

            </LinearLayout>

            <!-- Empty State -->
            <LinearLayout
                android:id="@+id/layout_empty"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="32dp"
                android:visibility="gone">

                <ImageView
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:alpha="0.5"
                    android:src="@drawable/ic_bookmark_outline"
                    android:contentDescription="Tidak ditemukan"
                    app:tint="@color/tertiary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Arsip Tidak Ditemukan"
                    android:fontFamily="@font/cinzel"
                    android:textAppearance="?attr/textAppearanceTitleMedium"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:text="Silakan gunakan kata kunci pencarian naskah yang lain."
                    android:fontFamily="@font/cormorant_garamond"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="@color/text_secondary" />

            </LinearLayout>

            <!-- Error State -->
            <LinearLayout
                android:id="@+id/layout_error"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="32dp"
                android:visibility="gone">

                <ImageView
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:alpha="0.5"
                    android:src="@drawable/ic_error_state"
                    android:contentDescription="@string/error_loading"
                    app:tint="@color/primary" />

                <TextView
                    android:id="@+id/text_error_message"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/error_loading"
                    android:fontFamily="@font/cinzel"
                    android:textAppearance="?attr/textAppearanceTitleMedium"
                    android:textColor="@color/text_primary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_retry"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/retry"
                    android:fontFamily="@font/cinzel"
                    android:backgroundTint="@color/primary"
                    app:cornerRadius="8dp" />

            </LinearLayout>

        </FrameLayout>

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
