<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/bg_parchment_card"
    android:padding="12dp"
    android:gravity="center_vertical"
    android:layout_marginBottom="8dp">

    <!-- Color indicator strip -->
    <View
        android:id="@+id/view_color_indicator"
        android:layout_width="6dp"
        android:layout_height="match_parent"
        android:layout_gravity="fill_vertical"
        android:background="#FFE082"
        android:layout_marginEnd="10dp" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/text_highlight_quote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="&quot;Teks terpilih yang disorot&quot;"
            android:textColor="#3E2723"
            android:textSize="13sp"
            android:textStyle="italic" />

        <TextView
            android:id="@+id/text_highlight_date"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="12 Jun 2026"
            android:textColor="#8D6E63"
            android:textSize="11sp" />

    </LinearLayout>

    <ImageButton
        android:id="@+id/btn_delete_highlight"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_delete"
        app:tint="#8D6E63"
        android:contentDescription="Hapus Sorotan" />

</LinearLayout>
